# ===========================================
# RingByRing Self-Serve Environment Variables
# ===========================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (configure in Stripe dashboard)
STRIPE_SETUP_FEE_PRICE_ID=price_xxx
STRIPE_MONTHLY_PRICE_ID=price_xxx

# Twilio
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER_POOL_SID=xxx

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# RingByRing Pipecat Server (existing infrastructure)
RINGBYRING_PIPECAT_SERVER_URL=https://your-pipecat-server.run.app
